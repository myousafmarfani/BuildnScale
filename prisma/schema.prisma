generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  data          UserData[]
  monitoredSites MonitoredSite[]
}

model UserData {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MonitoredSite {
  id                   String        @id @default(uuid()) @db.Uuid
  userId               String
  url                  String
  displayName          String?       @map("display_name")
  checkIntervalMinutes Int           @default(5) @map("check_interval_minutes")
  isActive             Boolean       @default(true) @map("is_active")
  createdAt            DateTime      @default(now()) @map("created_at")

  uptimeChecks UptimeCheck[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@map("monitored_sites")
}

model UptimeCheck {
  id               String         @id @default(uuid()) @db.Uuid
  siteId           String?        @map("site_id") @db.Uuid
  url              String
  checkedAt        DateTime       @default(now()) @map("checked_at")
  isUp             Boolean        @map("is_up")
  statusCode       Int?           @map("status_code")
  responseMs       Int?           @map("response_ms")
  region           String?
  sslValid         Boolean?       @map("ssl_valid")
  sslDaysRemaining Int?           @map("ssl_days_remaining")
  errorMessage     String?        @map("error_message")

  site MonitoredSite? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, checkedAt(sort: Desc)])
  @@index([url, checkedAt(sort: Desc)])
  @@map("uptime_checks")
}
